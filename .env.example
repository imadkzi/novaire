NUXT_PUBLIC_SITE_URL=https://novaire.co.uk

# Quote form — set ONE delivery method for production (required on Netlify)
NUXT_QUOTE_TO_EMAIL=enquiries@novaire.co.uk
# Resend verified sender (must match a domain verified in Resend)
NUXT_QUOTE_FROM_EMAIL=Novaire <enquiries@novaire.co.uk>
# Option A: Formspree (client posts directly to Formspree)
NUXT_PUBLIC_FORMSPREE_ID=
# Option B: Resend (server route /api/quote sends email)
NUXT_RESEND_API_KEY=
# Optional: Zapier/Make/HubSpot webhook after successful Resend delivery
NUXT_CRM_WEBHOOK_URL=

# Optional: shown in header, footer, and contact page
NUXT_PUBLIC_PHONE_NUMBER=
# Optional: digits only or with +, e.g. 447700900000 for wa.me links
NUXT_PUBLIC_WHATSAPP_NUMBER=

# Optional: analytics (Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX)
NUXT_PUBLIC_GA_ID=

# Legal entity (shown on Privacy and Terms pages)
NUXT_PUBLIC_LEGAL_NAME=Novaire London PLC
NUXT_PUBLIC_LEGAL_COMPANY_NUMBER=14837291
NUXT_PUBLIC_LEGAL_REGISTERED_ADDRESS=2nd Floor, 32 Kensington Church Street, London, W8 4HA, United Kingdom
NUXT_PUBLIC_LEGAL_EMAIL=enquiries@novaire.co.uk
